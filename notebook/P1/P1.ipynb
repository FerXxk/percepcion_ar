    "img_hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)\n",
    "\n",
    "# 2. Rangos de colores en HSV\n",
    "# Azul\n",
    "blue_lower_hsv = np.array([100, 100, 100])\n",
    "blue_upper_hsv = np.array([130, 255, 255])\n",
    "\n",
    "# Amarillo\n",
    "yellow_lower_hsv = np.array([20, 100, 100])\n",
    "yellow_upper_hsv = np.array([35, 255, 255])\n",
    "\n",
    "# 3. Crear máscaras\n",
    "mask_blue_hsv = cv2.inRange(img_hsv, blue_lower_hsv, blue_upper_hsv)\n",
    "mask_yellow_hsv = cv2.inRange(img_hsv, yellow_lower_hsv, yellow_upper_hsv)\n",
    "mask_hsv = cv2.bitwise_or(mask_blue_hsv, mask_yellow_hsv)\n",
    "\n",
    "# 4. Aplicar máscara\n",
    "result_hsv = cv2.bitwise_and(img_rgb, img_rgb, mask=mask_hsv)\n",
    "\n",
    "# 5. Mostrar\n",
    "imshow(img_rgb, \"Original\")\n",
    "imshow(mask_hsv, \"Máscara HSV\", cmap=\"gray\")\n",
    "imshow(result_hsv, \"Resultado HSV\")\n"
   ]
