    "# Cargamos la imagen de nuevo para este ejercicio\n",
    "rows, cols = img.shape[:2]\n",
    "\n",
    "# --- 1. TRASLACIÓN ---\n",
    "tx, ty = 100, 50\n",
    "M_traslacion = np.float32([[1, 0, tx], [0, 1, ty]])\n",
    "img_trasladada = cv2.warpAffine(img, M_traslacion, (cols, rows))\n",
    "\n",
    "# --- 2. ESCALA ---\n",
    "sx, sy = 1.5, 1.5\n",
    "M_escala = np.float32([[sx, 0, 0], [0, sy, 0]])\n",
    "img_escalada = cv2.warpAffine(img, M_escala, (int(cols*sx), int(rows*sy)))\n",
    "\n",
    "# --- 3. ROTACIÓN (OpenCV) ---\n",
    "centro = (cols // 2, rows // 2)\n",
    "M_rot = cv2.getRotationMatrix2D(centro, 45, 1.0)\n",
    "img_rotada = cv2.warpAffine(img, M_rot, (cols, rows))\n",
    "\n",
    "# --- 4. INCLINACIÓN (SHEAR simple) ---\n",
    "shear_factor = 0.2\n",
    "M_shear = np.float32([[1, 0, 0], [shear_factor, 1, 0]])\n",
    "img_sheared = cv2.warpAffine(img, M_shear, (int(cols + rows*shear_factor), rows))\n",
    "\n",
    "# --- 5. ROTACIÓN 45° USANDO SOLO SHEAR (Algoritmo de Paeth) ---\n",
    "theta = np.deg2rad(45)\n",
    "alpha = -np.tan(theta / 2)\n",
    "beta = np.sin(theta)\n",
    "cx, cy = cols / 2, rows / 2\n",
    "\n",
    "M1 = np.float32([[1, alpha, -alpha * cy], [0, 1, 0]])\n",
    "img_s1 = cv2.warpAffine(img, M1, (cols, rows))\n",
    "\n",
    "M2 = np.float32([[1, 0, 0], [beta, 1, -beta * cx]])\n",
    "img_s2 = cv2.warpAffine(img_s1, M2, (cols, rows))\n",
    "\n",
    "M3 = np.float32([[1, alpha, -alpha * cy], [0, 1, 0]])\n",
    "img_rotada_shear = cv2.warpAffine(img_s2, M3, (cols, rows))\n",
    "\n",
    "plt.figure(figsize=(15, 10))\n",
    "plt.subplot(231), plt.imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB)), plt.title('Original')\n",
    "plt.subplot(232), plt.imshow(cv2.cvtColor(img_trasladada, cv2.COLOR_BGR2RGB)), plt.title('Traslación')\n",
    "plt.subplot(233), plt.imshow(cv2.cvtColor(img_escalada, cv2.COLOR_BGR2RGB)), plt.title('Escala (1.5x)')\n",
    "plt.subplot(234), plt.imshow(cv2.cvtColor(img_rotada, cv2.COLOR_BGR2RGB)), plt.title('Rotación OpenCV (45°)')\n",
    "plt.subplot(235), plt.imshow(cv2.cvtColor(img_sheared, cv2.COLOR_BGR2RGB)), plt.title('Shear simple')\n",
    "plt.subplot(236), plt.imshow(cv2.cvtColor(img_rotada_shear, cv2.COLOR_BGR2RGB)), plt.title('Rotación 3-Shear (45°)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
