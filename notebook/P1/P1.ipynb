    "# 1. Cargar imagen\n",
    "img = cv2.imread('images/Lego.png')\n",
    "\n",
    "# 2. Transformaciones\n",
    "img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "# 3. Filtrado por color en RGB\n",
    "# Azul (B es alto, R y G bajos)\n",
    "blue_lower = np.array([0, 0, 100])\n",
    "blue_upper = np.array([100, 100, 255])\n",
    "\n",
    "# Amarillo (R y G altos, B bajo)\n",
    "yellow_lower = np.array([150, 150, 0])\n",
    "yellow_upper = np.array([255, 255, 120])\n",
    "\n",
    "mask_blue = cv2.inRange(img_rgb, blue_lower, blue_upper)\n",
    "mask_yellow = cv2.inRange(img_rgb, yellow_lower, yellow_upper)\n",
    "mask_combined = cv2.bitwise_or(mask_blue, mask_yellow)\n",
    "\n",
    "res_rgb = cv2.bitwise_and(img_rgb, img_rgb, mask=mask_combined)\n",
    "\n",
    "imshow(img_rgb, \"Original\")\n",
    "imshow(mask_combined, \"Máscara Combinada RGB\", cmap='gray')\n",
    "imshow(res_rgb, \"Resultado Filtrado RGB\")\n"
   ]
  },
